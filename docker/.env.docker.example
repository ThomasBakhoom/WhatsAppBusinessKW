# docker-compose environment file.
# Copy to `.env.docker` and fill in real secrets.
# `.env.docker` MUST NOT be committed (see .gitignore).
#
# Generate strong secrets with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=__replace_me__
JWT_SECRET_KEY=__replace_me__
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=kwgrowth
POSTGRES_USER=kwgrowth
POSTGRES_PASSWORD=__replace_me__
DATABASE_URL=postgresql+asyncpg://kwgrowth:__replace_me__@db:5432/kwgrowth

# Runtime DB role - non-superuser. RLS policies only take effect when the
# API connects under a role without BYPASSRLS/SUPERUSER. The schema owner
# (POSTGRES_USER) is reserved for Alembic migrations.
APP_DB_USER=app_user
APP_DB_PASSWORD=__replace_me__

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=kwgrowth
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=__replace_me__
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_BUSINESS_ACCOUNT_ID=

# ── Tap Payments ─────────────────────────────────────────────────────────────
TAP_SECRET_KEY=
TAP_PUBLISHABLE_KEY=
TAP_WEBHOOK_SECRET=

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
