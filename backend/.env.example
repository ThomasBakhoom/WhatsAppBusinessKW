# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key-in-production
APP_NAME="Kuwait WhatsApp Growth Engine"
APP_VERSION=0.1.0
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://kwgrowth:kwgrowth_dev@localhost:5432/kwgrowth
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# WhatsApp Cloud API (Primary)
WHATSAPP_PROVIDER=cloud_api
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=change-me-to-a-random-verify-token

# Twilio (Fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Tap Payments (K-Net)
TAP_SECRET_KEY=
TAP_PUBLISHABLE_KEY=
TAP_WEBHOOK_SECRET=

# S3-Compatible Storage (MinIO for dev, AWS S3 for prod)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=kwgrowth
S3_REGION=us-east-1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Sentry (optional)
SENTRY_DSN=

# AI/Claude API (for Kuwaiti dialect engine)
ANTHROPIC_API_KEY=
